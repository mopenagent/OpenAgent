{
    "name": "browser",
    "description": "Headless browser automation via agent-browser CLI (npm install -g agent-browser && agent-browser install). Persistent named sessions \u2014 isolated cookies/storage per session_id. Screenshots written to data/artifacts/browser/<session_id>/latest.png.",
    "version": "0.1.0",
    "binary": {
        "linux/arm64": "bin/browser-linux-arm64",
        "linux/amd64": "bin/browser-linux-amd64",
        "darwin/arm64": "bin/browser-darwin-arm64",
        "darwin/amd64": "bin/browser-darwin-amd64"
    },
    "socket": "data/sockets/browser.sock",
    "health": {
        "interval_ms": 5000,
        "timeout_ms": 2000,
        "restart_backoff_ms": [
            1000,
            2000,
            5000,
            10000,
            30000
        ]
    },
    "tools": [
        {
            "name": "browser.open",
            "description": "Open a URL in a new or existing named browser session. Returns session_id and screenshot path.",
            "params": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string"
                    },
                    "session_id": {
                        "type": "string",
                        "description": "Optional: reuse existing session"
                    }
                },
                "required": [
                    "url"
                ]
            }
        },
        {
            "name": "browser.navigate",
            "description": "Navigate an existing session to a new URL.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "url": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "url"
                ]
            }
        },
        {
            "name": "browser.snapshot",
            "description": "Get accessibility tree (AI-optimized, with @ref IDs for elements) + screenshot. Use @e1, @e2 refs in click/fill/type.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "interactive_only": {
                        "type": "boolean",
                        "description": "Only interactive elements (default false)"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.screenshot",
            "description": "Take a screenshot of the current page.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "full_page": {
                        "type": "boolean",
                        "description": "Full-page scroll screenshot"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.click",
            "description": "Click an element by CSS selector, @ref (from snapshot), or pixel coordinates x+y. Set new_tab=true to open in new tab.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string",
                        "description": "CSS selector or @ref e.g. @e2"
                    },
                    "x": {
                        "type": "number"
                    },
                    "y": {
                        "type": "number"
                    },
                    "new_tab": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.dblclick",
            "description": "Double-click an element by CSS selector or @ref.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.fill",
            "description": "Clear an input and fill with text. Preferred over type for form fields.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string",
                        "description": "CSS selector or @ref"
                    },
                    "text": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.type",
            "description": "Type text (appends, does not clear). Optionally focus a selector first, or omit for raw keyboard input.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "text": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string",
                        "description": "CSS selector or @ref (optional)"
                    }
                },
                "required": [
                    "session_id",
                    "text"
                ]
            }
        },
        {
            "name": "browser.press",
            "description": "Press a key or combination: Enter, Tab, Escape, Control+a, ArrowDown, etc.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "key": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "key"
                ]
            }
        },
        {
            "name": "browser.hover",
            "description": "Hover over an element (triggers tooltips, dropdown menus).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.select",
            "description": "Select an option value in a <select> dropdown.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string",
                        "description": "Option value to select"
                    }
                },
                "required": [
                    "session_id",
                    "selector",
                    "value"
                ]
            }
        },
        {
            "name": "browser.check",
            "description": "Check a checkbox. Set uncheck=true to uncheck instead.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    },
                    "uncheck": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.scroll",
            "description": "Scroll the page or a specific element up/down/left/right.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "direction": {
                        "type": "string",
                        "enum": [
                            "up",
                            "down",
                            "left",
                            "right"
                        ]
                    },
                    "amount": {
                        "type": "number",
                        "description": "Pixels (default 500)"
                    },
                    "selector": {
                        "type": "string",
                        "description": "Scroll inside this element (optional)"
                    }
                },
                "required": [
                    "session_id",
                    "direction"
                ]
            }
        },
        {
            "name": "browser.scrollinto",
            "description": "Scroll an element into the visible viewport.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.find",
            "description": "Find and interact with elements by semantic attributes. by: role, text, label, placeholder, alt, testid, title, first, last, nth. Use n when by=nth. Pass action_value for fill. Pass exact=true for exact text. Pass name to filter role by accessible name.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "by": {
                        "type": "string",
                        "enum": [
                            "role",
                            "text",
                            "label",
                            "placeholder",
                            "alt",
                            "testid",
                            "title",
                            "first",
                            "last",
                            "nth"
                        ]
                    },
                    "value": {
                        "type": "string",
                        "description": "Value to match (or selector for first/last/nth)"
                    },
                    "action": {
                        "type": "string",
                        "description": "click, fill, check, hover, focus (default: click)"
                    },
                    "action_value": {
                        "type": "string",
                        "description": "Value for fill action (e.g. text to enter)"
                    },
                    "n": {
                        "type": "number",
                        "description": "Index when by=nth (1-based)"
                    },
                    "exact": {
                        "type": "boolean",
                        "description": "Exact text match only"
                    },
                    "name": {
                        "type": "string",
                        "description": "Filter by accessible name (for role)"
                    }
                },
                "required": [
                    "session_id",
                    "by",
                    "value"
                ]
            }
        },
        {
            "name": "browser.get",
            "description": "Get data from the page: text, html, value, attr, title, url, count, box, styles.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "what": {
                        "type": "string",
                        "enum": [
                            "text",
                            "html",
                            "value",
                            "attr",
                            "title",
                            "url",
                            "count",
                            "box",
                            "styles"
                        ]
                    },
                    "selector": {
                        "type": "string",
                        "description": "CSS selector (required for text/html/value/attr/count/box)"
                    },
                    "attr": {
                        "type": "string",
                        "description": "Attribute name (for what=attr)"
                    }
                },
                "required": [
                    "session_id",
                    "what"
                ]
            }
        },
        {
            "name": "browser.wait",
            "description": "Wait for: element visible (selector), text to appear, URL pattern, load state, or N milliseconds.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    },
                    "text": {
                        "type": "string"
                    },
                    "url_pattern": {
                        "type": "string"
                    },
                    "load_state": {
                        "type": "string",
                        "enum": [
                            "load",
                            "domcontentloaded",
                            "networkidle"
                        ]
                    },
                    "ms": {
                        "type": "number"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.eval",
            "description": "Evaluate JavaScript in the page context and return the result.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "js": {
                        "type": "string",
                        "description": "JavaScript expression"
                    }
                },
                "required": [
                    "session_id",
                    "js"
                ]
            }
        },
        {
            "name": "browser.extract",
            "description": "Extract readable text content from the full page or scoped to a CSS selector.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string",
                        "description": "Scope to element (optional)"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.tab_new",
            "description": "Open a new browser tab in this session, optionally navigating to a URL.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "url": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.tab_switch",
            "description": "Switch to tab N (1-indexed) in this session.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "n": {
                        "type": "number",
                        "description": "Tab number (1-indexed)"
                    }
                },
                "required": [
                    "session_id",
                    "n"
                ]
            }
        },
        {
            "name": "browser.cookies",
            "description": "Manage cookies: get all, set a named cookie, or clear all.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "get",
                            "set",
                            "clear"
                        ]
                    },
                    "name": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.state",
            "description": "Save or load browser auth state (cookies, localStorage) for this session.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "save",
                            "load"
                        ]
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.pdf",
            "description": "Export the current page as PDF. Saved to data/artifacts/browser/<session_id>/page.pdf.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.diff",
            "description": "Diff current page snapshot or screenshot vs the last state or a baseline file.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string",
                        "enum": [
                            "snapshot",
                            "screenshot"
                        ]
                    },
                    "baseline": {
                        "type": "string",
                        "description": "Baseline file path (for screenshot diff)"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.close",
            "description": "Close this browser session and release its resources.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.back",
            "description": "Navigate back to the previous page.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.forward",
            "description": "Navigate forward to the next page.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.reload",
            "description": "Reload the current page.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.focus",
            "description": "Focus an element without clicking it.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.drag",
            "description": "Drag source element onto target element (CSS selectors or @refs).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "source": {
                        "type": "string"
                    },
                    "target": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "source",
                    "target"
                ]
            }
        },
        {
            "name": "browser.upload",
            "description": "Upload a file to a file input element.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string"
                    },
                    "file": {
                        "type": "string",
                        "description": "Absolute path to file"
                    }
                },
                "required": [
                    "session_id",
                    "selector",
                    "file"
                ]
            }
        },
        {
            "name": "browser.keydown",
            "description": "Hold a modifier key down (Shift, Control, Alt, Meta). Pair with browser.keyup.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "key": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "key"
                ]
            }
        },
        {
            "name": "browser.keyup",
            "description": "Release a held modifier key.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "key": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "key"
                ]
            }
        },
        {
            "name": "browser.frame",
            "description": "Switch to an iframe (selector) or back to the main frame (selector='main').",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "selector": {
                        "type": "string",
                        "description": "CSS selector for iframe, or 'main' (default)"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.dialog",
            "description": "Accept or dismiss a browser alert/confirm/prompt dialog.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "accept",
                            "dismiss"
                        ]
                    },
                    "text": {
                        "type": "string",
                        "description": "Text for prompt dialogs"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.is",
            "description": "Check element state: visible, enabled, or checked. Returns boolean.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "check": {
                        "type": "string",
                        "enum": [
                            "visible",
                            "enabled",
                            "checked"
                        ]
                    },
                    "selector": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "selector"
                ]
            }
        },
        {
            "name": "browser.tab_list",
            "description": "List all open tabs in this session.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.tab_close",
            "description": "Close current tab or tab N (1-indexed).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "n": {
                        "type": "number"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.storage",
            "description": "Read/write localStorage or sessionStorage. store=local|session, action=get|set|clear.",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "store": {
                        "type": "string",
                        "enum": [
                            "local",
                            "session"
                        ]
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "get",
                            "set",
                            "clear"
                        ]
                    },
                    "key": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.set",
            "description": "Configure browser. what: viewport(width,height), device(name), geo(lat,lng), offline(value=on/off), headers(json), credentials(username,password), media(scheme=dark/light).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "what": {
                        "type": "string",
                        "enum": [
                            "viewport",
                            "device",
                            "geo",
                            "offline",
                            "headers",
                            "credentials",
                            "media"
                        ]
                    },
                    "width": {
                        "type": "number"
                    },
                    "height": {
                        "type": "number"
                    },
                    "name": {
                        "type": "string"
                    },
                    "lat": {
                        "type": "number"
                    },
                    "lng": {
                        "type": "number"
                    },
                    "value": {
                        "type": "string"
                    },
                    "json": {
                        "type": "string"
                    },
                    "username": {
                        "type": "string"
                    },
                    "password": {
                        "type": "string"
                    },
                    "scheme": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id",
                    "what"
                ]
            }
        },
        {
            "name": "browser.network",
            "description": "Intercept or inspect requests. action=route(url_pattern, abort or body), unroute(url_pattern), requests(filter).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "route",
                            "unroute",
                            "requests"
                        ]
                    },
                    "url_pattern": {
                        "type": "string"
                    },
                    "abort": {
                        "type": "boolean"
                    },
                    "body": {
                        "type": "string"
                    },
                    "filter": {
                        "type": "string"
                    }
                },
                "required": [
                    "session_id"
                ]
            }
        },
        {
            "name": "browser.mouse",
            "description": "Low-level mouse control. action: move(x,y), down(button), up(button), wheel(dy,dx).",
            "params": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "move",
                            "down",
                            "up",
                            "wheel"
                        ]
                    },
                    "x": {
                        "type": "number"
                    },
                    "y": {
                        "type": "number"
                    },
                    "button": {
                        "type": "string",
                        "enum": [
                            "left",
                            "right",
                            "middle"
                        ]
                    },
                    "dy": {
                        "type": "number"
                    },
                    "dx": {
                        "type": "number"
                    }
                },
                "required": [
                    "session_id",
                    "action"
                ]
            }
        },
