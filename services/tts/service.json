{
    "name": "tts",
    "description": "Kokoro TTS via Kokoros — local, fast, no API key. Supports streaming-style playback via synthesize_bytes. Model: Kokoro-82M (~400 MB RSS warmed). Models stored in data/models/.",
    "version": "0.1.0",
    "binary": {
        "linux/arm64": "bin/tts-linux-arm64",
        "linux/amd64": "bin/tts-linux-amd64",
        "darwin/arm64": "bin/tts-darwin-arm64",
        "darwin/amd64": "bin/tts-darwin-amd64"
    },
    "socket": "data/sockets/tts.sock",
    "health": {
        "interval_ms": 5000,
        "timeout_ms": 3000,
        "restart_backoff_ms": [1000, 2000, 5000, 10000, 30000]
    },
    "tools": [
        {
            "name": "tts.synthesize",
            "description": "Synthesize speech from text. Writes WAV to data/artifacts/tts. Returns path and sample_rate.",
            "params": {
                "type": "object",
                "properties": {
                    "text": { "type": "string", "description": "Text to speak" },
                    "voice": { "type": "string", "description": "Voice style (af_sarah, af_nicole, af_sky, or blend af_sarah.4+af_nicole.6)" },
                    "speed": { "type": "number", "description": "Speech rate (default 1.0)" },
                    "language": { "type": "string", "description": "Language code (default en-us)" }
                },
                "required": ["text"]
            }
        },
        {
            "name": "tts.synthesize_bytes",
            "description": "Synthesize to base64 f32 PCM. For streaming playback without writing to file.",
            "params": {
                "type": "object",
                "properties": {
                    "text": { "type": "string", "description": "Text to speak" },
                    "voice": { "type": "string", "description": "Voice style" },
                    "speed": { "type": "number", "description": "Speech rate" },
                    "language": { "type": "string", "description": "Language code" }
                },
                "required": ["text"]
            }
        }
    ],
    "events": [],
    "runtime": "rust"
}
