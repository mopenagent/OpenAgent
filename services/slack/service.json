{
    "name": "slack",
    "description": "Slack bot service using slack-go/slack over MCP-lite.",
    "version": "0.1.0",
    "binary": {
        "linux/arm64": "bin/slack-linux-arm64",
        "linux/amd64": "bin/slack-linux-amd64",
        "darwin/arm64": "bin/slack-darwin-arm64",
        "darwin/amd64": "bin/slack-darwin-amd64"
    },
    "socket": "data/sockets/slack.sock",
    "health": {
        "interval_ms": 5000,
        "timeout_ms": 1000,
        "restart_backoff_ms": [
            1000,
            2000,
            5000,
            10000,
            30000
        ]
    },
    "tools": [
        {
            "name": "slack.status",
            "description": "Return current Slack service status.",
            "params": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "slack.link_state",
            "description": "Return current Slack connection and auth state.",
            "params": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "slack.send_message",
            "description": "Send a message to a Slack channel.",
            "params": {
                "type": "object",
                "properties": {
                    "channel_id": {
                        "type": "string",
                        "description": "Slack channel ID."
                    },
                    "text": {
                        "type": "string",
                        "description": "Message text."
                    }
                },
                "required": [
                    "channel_id",
                    "text"
                ]
            }
        }
    ],
    "events": [
        "slack.connection.status",
        "slack.message.received"
    ],
    "runtime": "go"
}