{
  "name": "filesystem",
  "description": "Comprehensive local filesystem service over MCP-lite.",
  "version": "0.1.0",
  "binary": {
    "linux/arm64": "bin/filesystem-linux-arm64",
    "linux/amd64": "bin/filesystem-linux-amd64",
    "darwin/arm64": "bin/filesystem-darwin-arm64"
  },
  "socket": "data/sockets/filesystem.sock",
  "health": {
    "interval_ms": 5000,
    "timeout_ms": 1000,
    "restart_backoff_ms": [1000, 2000, 5000, 10000, 30000]
  },
  "tools": [
    {
      "name": "filesystem.search",
      "description": "Search filesystem paths by substring match.",
      "params": {"type": "object", "properties": {"query": {"type": "string"}}, "required": ["query"]}
    },
    {
      "name": "filesystem.list_dir",
      "description": "List directory entries.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}
    },
    {
      "name": "filesystem.read_file",
      "description": "Read file content.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}
    },
    {
      "name": "filesystem.write_file",
      "description": "Write content to file.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}, "content": {"type": "string"}}, "required": ["path", "content"]}
    },
    {
      "name": "filesystem.append_file",
      "description": "Append content to file.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}, "content": {"type": "string"}}, "required": ["path", "content"]}
    },
    {
      "name": "filesystem.edit_file",
      "description": "Edit file by replacing exact text.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}, "old_text": {"type": "string"}, "new_text": {"type": "string"}}, "required": ["path", "old_text", "new_text"]}
    },
    {
      "name": "filesystem.stat",
      "description": "Get file or directory metadata.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}
    },
    {
      "name": "filesystem.mkdir",
      "description": "Create directory.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}
    },
    {
      "name": "filesystem.delete",
      "description": "Delete file or directory.",
      "params": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}
    },
    {
      "name": "filesystem.move",
      "description": "Move or rename file/directory.",
      "params": {"type": "object", "properties": {"src": {"type": "string"}, "dst": {"type": "string"}}, "required": ["src", "dst"]}
    },
    {
      "name": "filesystem.copy",
      "description": "Copy file/directory recursively.",
      "params": {"type": "object", "properties": {"src": {"type": "string"}, "dst": {"type": "string"}}, "required": ["src", "dst"]}
    },
    {
      "name": "filesystem.glob",
      "description": "Match paths with glob pattern.",
      "params": {"type": "object", "properties": {"pattern": {"type": "string"}}, "required": ["pattern"]}
    }
  ],
  "events": []
}
