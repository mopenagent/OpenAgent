{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.agno.com)",
      "WebFetch(domain:www.digitalocean.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(source .venv/bin/activate)",
      "Bash(pytest openagent/tests/ -v)",
      "Bash(.venv/bin/pytest app/tests/ -x -q)",
      "WebFetch(domain:docs.microsandbox.dev)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-bash.sh"
          }
        ]
      }
    ]
  }
}
